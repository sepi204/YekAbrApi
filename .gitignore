## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio cache/options directory
.vs/

# Rider
.idea/

# VS Code
.vscode/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# DotNet restore lock file if you don't want to track it
# Uncomment if needed:
# packages.lock.json

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# DotCover
*.dotCover

# Azure / publish
PublishProfiles/
*.azurePubxml
*.pubxml
*.publishproj

# IIS Express
iisexpress/
*.dbmdl

# SQL Server files
*.mdf
*.ldf

# Logs
*.log

# Runtime files
appsettings.Development.json

# OS generated files
.DS_Store
Thumbs.db

# Node modules if you have frontend assets
node_modules/

# Coverage
coverage/
*.coverage
*.coveragexml

# Generated files
Generated\ Files/

# Backup & temporary files
*.tmp
*.temp
*.bak
*.backup
